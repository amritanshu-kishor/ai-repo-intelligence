# =============================================================================
# Repository Intelligence — copy to .env and fill in your keys
# =============================================================================

# --- Provider (pick one) ---
# groq        → Best free option: fast Llama 3.3 70B — https://console.groq.com
# gemini      → Google free tier — https://aistudio.google.com/apikey
# openrouter  → Multiple models, some free — https://openrouter.ai/keys
# huggingface → HF Inference — https://huggingface.co/settings/tokens
# watsonx     → IBM Cloud — https://www.ibm.com/watsonx
# mock        → Offline placeholder replies (no API key)
LLM_PROVIDER=groq

USE_MOCK_LLM=false
USE_MOCK_DATA=false

LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# --- Groq (recommended) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# --- Hugging Face ---
HF_API_TOKEN=your_hf_token_here
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
HF_INFERENCE_URL=https://router.huggingface.co/v1/chat/completions

# --- IBM watsonx ---
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --- Parser backend ---
PARSER_WORKFLOW_URL=http://127.0.0.1:8001
