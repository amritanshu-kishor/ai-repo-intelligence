# ============================================
# AI Repository Intelligence Platform
# Environment Configuration Template
# ============================================
# Copy this file to .env and configure as needed

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true
API_WORKERS=1

# CORS Configuration
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000","http://localhost:3000"]

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=repository_embeddings

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# AI/Embeddings Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
MAX_EMBEDDING_BATCH_SIZE=32

# Graph Configuration
MAX_GRAPH_NODES=10000
MAX_GRAPH_EDGES=50000
DEFAULT_GRAPH_LAYOUT=cose

# Repository Processing
MAX_FILE_SIZE_MB=10
SUPPORTED_LANGUAGES=python,javascript,typescript,java,go,rust
TEMP_UPLOAD_DIR=./temp_uploads

# Analytics Configuration
ENABLE_ANALYTICS=true
ANALYTICS_CACHE_TTL=3600

# Development
DEBUG=false
TESTING=false